model EventTier {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String   @unique
  description  String
  meritAmount  Int
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  eventSessions EventSession[]

  @@index([isActive, displayOrder])
}
