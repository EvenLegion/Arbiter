enum EventSessionMessageKind {
  ACTIVE
  TRACKING_SUMMARY
  TRACKING_SUMMARY_PARENT_VC
  REVIEW
}

model EventSessionMessage {
  id             Int                     @id @default(autoincrement())
  eventSessionId Int
  kind           EventSessionMessageKind
  channelId      String
  messageId      String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  eventSession EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

  @@unique([eventSessionId, kind])
  @@unique([channelId, messageId])
}
