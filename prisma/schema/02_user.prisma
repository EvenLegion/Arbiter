model User {
  id String @id @default(uuid())

  discordUserId    String @unique
  discordUsername  String
  discordNickname  String
  discordAvatarUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  divisionMemberships DivisionMembership[]

  nameChangeRequests         NameChangeRequest[] @relation("NameChangeRequestRequesterUser")
  reviewedNameChangeRequests NameChangeRequest[] @relation("NameChangeRequestReviewerUser")

  hostedEventSessions       Event[]         @relation("EventSessionHostUser")
  finalizedEventSessions    Event[]         @relation("EventSessionFinalizedByUser")
  addedEventSessionChannels EventChannel[]  @relation("EventSessionChannelAddedByUser")
  eventParticipantStats     EventParticipantStat[] @relation("EventParticipantStatUser")
  targetEventDecisions      EventReviewDecision[]  @relation("EventReviewDecisionTargetUser")

  merits        Merit[] @relation("MeritRecipientUser")
  awardedMerits Merit[] @relation("MeritAwarderUser")
}
