# Environment configuration for Arbiter

# App environment: development | production
NODE_ENV=development

# File-first logging configuration
# Arbiter always writes structured logs to LOG_FILE_PATH.
LOG_FILE_PATH=logs/arbiter.log
# File log level: trace | debug | info | warn | error
FILE_LOG_LEVEL=debug
# Optional console mirror level: trace | debug | info | warn | error | silent
CONSOLE_LOG_LEVEL=info
# Pretty-print console output when console logging is enabled.
ENABLE_CONSOLE_PRETTY_LOGS=true

# Database config
POSTGRES_DOCKER_VERSION=postgres:17-alpine
POSTGRES_USER=arbiter
POSTGRES_PASSWORD=arbiter
POSTGRES_DB=arbiter
POSTGRES_PORT=5432
DATABASE_URL=postgresql://arbiter:arbiter@localhost:5432/arbiter

# Migration-specific overrides (optional)
# MIGRATION_TARGET_DATABASE_URL=postgresql://arbiter:arbiter@localhost:5432/arbiter
# MIGRATION_SOURCE_DATABASE_URL=postgresql://legacy_user:legacy_password@localhost:5433/legacy_db
# MIGRATION_DISCORD_BOT_TOKEN=
# MIGRATION_DISCORD_GUILD_ID=

# Redis (required by @sapphire/plugin-scheduled-tasks and event tracking storage)
REDIS_DOCKER_VERSION=redis:7-alpine
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=arbiter
REDIS_DB=0

# Production Docker (optional)
# Observability image versions
# LOKI_DOCKER_VERSION=3.5.6
# ALLOY_DOCKER_VERSION=v1.14.0
# GRAFANA_DOCKER_VERSION=12.2.0
#
# REDIS_DATA_DIR=/opt/arbiter/redis-data
# BOT_LOGS_DIR=/opt/arbiter/bot-logs
# LOKI_DATA_DIR=/opt/arbiter/loki-data
# GRAFANA_DATA_DIR=/opt/arbiter/grafana-data
# ALLOY_DATA_DIR=/opt/arbiter/alloy-data
# BOT_MEM_LIMIT=768m
# BOT_CPUS=1.0
# REDIS_MEM_LIMIT=256m
# REDIS_CPUS=0.5
# LOKI_MEM_LIMIT=512m
# LOKI_CPUS=0.5
# GRAFANA_MEM_LIMIT=256m
# GRAFANA_CPUS=0.5
# ALLOY_MEM_LIMIT=128m
# ALLOY_CPUS=0.25
# BOT_UID=1000
# BOT_GID=1000
# REDIS_UID=999
# REDIS_GID=999
# GRAFANA_PORT=3001
# LOKI_PORT=3100
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me
# ARBITER_IMAGE_TAG=latest

# Discord bot token (required to run the bot)
DISCORD_TOKEN=
DISCORD_GUILD_ID=1456506010587107532

# Other config
MEMBER_ROLE_SYNC_DEBOUNCE_MS=1000
DIVISION_CACHE_REFRESH_CRON=0 2 * * * # Runs at 2:00 AM UTC
EVENT_REVIEW_PAGE_SIZE=4
EVENT_REVIEW_FINALIZED_PAGE_SIZE=10
EVENT_TRACKING_INTERVAL_SECONDS=60

# Test environment variables
TEST_CONTAINER_ENV_PATH=.testcontainer-env.json
TEST_DATABASE_NAME=arbiter_test
TEST_DATABASE_USERNAME=arbiter
TEST_DATABASE_PASSWORD=arbiter

