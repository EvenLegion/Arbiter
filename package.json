{
	"name": "arbiter",
	"version": "3.1.0",
	"packageManager": "pnpm@10.11.0",
	"main": "dist/index.js",
	"type": "commonjs",
	"dependencies": {
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@sapphire/cron": "^1.2.1",
		"@sapphire/decorators": "^6.1.1",
		"@sapphire/discord.js-utilities": "7.3.2",
		"@sapphire/framework": "^5.3.2",
		"@sapphire/plugin-scheduled-tasks": "^10.0.4",
		"@sapphire/plugin-subcommands": "^7.0.1",
		"@sapphire/plugin-utilities-store": "^2.0.3",
		"@sapphire/utilities": "^3.18.1",
		"@skyra/env-utilities": "^1.3.0",
		"colorette": "^2.0.20",
		"discord.js": "^14.17.3",
		"ioredis": "^5.9.3",
		"pg": "^8.19.0",
		"pino": "^10.1.0",
		"pino-pretty": "^13.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@docusaurus/core": "^3.9.2",
		"@docusaurus/preset-classic": "^3.9.2",
		"@docusaurus/theme-mermaid": "^3.9.2",
		"@mdx-js/react": "^3.1.1",
		"@sapphire/cli": "^1.9.3",
		"@sapphire/prettier-config": "^2.0.0",
		"@sapphire/ts-config": "^5.0.1",
		"@testcontainers/postgresql": "^11.12.0",
		"@testcontainers/redis": "^11.12.0",
		"@types/node": "^22.10.7",
		"@types/pg": "^8.16.0",
		"@types/ws": "^8.5.13",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@vitest/coverage-v8": "^4.1.0",
		"clsx": "^2.1.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.4.2",
		"prism-react-renderer": "^2.4.1",
		"prisma": "^7.4.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"testcontainers": "^11.12.0",
		"tsc-watch": "^6.3.0",
		"tsx": "^4.21.0",
		"typescript": "~5.4.5",
		"vitest": "^4.1.0"
	},
	"scripts": {
		"prepare": "husky",
		"postinstall": "prisma generate",
		"sapphire": "sapphire",
		"generate": "sapphire generate",
		"build": "tsc -p tsconfig.json",
		"docs:build": "cd website && node ../node_modules/@docusaurus/core/bin/docusaurus.mjs build",
		"docs:dev": "cd website && node ../node_modules/@docusaurus/core/bin/docusaurus.mjs start --host 0.0.0.0",
		"docs:serve": "cd website && node ../node_modules/@docusaurus/core/bin/docusaurus.mjs serve --host 0.0.0.0",
		"lint": "eslint src tests",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:coverage": "vitest run --coverage",
		"test:integration": "node scripts/test-integration.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -w",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"watch:start": "tsc-watch --onSuccess \"npm run start\"",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate deploy",
		"db:fetch:guild-members": "tsx prisma/migration/fetchGuildMembers.ts",
		"db:fetch:event-sessions": "tsx prisma/migration/fetchEventSession.ts",
		"db:seed:guild-members": "tsx prisma/migration/seedGuildMembers.ts",
		"db:seed:events": "tsx prisma/migration/seedEvent.ts",
		"db:seed:event-merits": "tsx prisma/migration/seedEventMerits.ts",
		"db:seed:non-event-merits": "tsx prisma/migration/seedNonEventMerits.ts",
		"db:verify:merit-rank": "tsx prisma/migration/verifyMeritRank.ts",
		"db:fix:sequences": "tsx prisma/migration/fixSequences.ts",
		"db:migrate:users": "pnpm db:fetch:guild-members && pnpm db:seed:guild-members",
		"release:plan": "node scripts/release/plan.mjs",
		"release:publish": "node scripts/release/publish.mjs",
		"db:up": "docker compose -f docker-compose.db.yml up -d",
		"db:down": "docker compose -f docker-compose.db.yml down",
		"db:reset": "docker compose -f docker-compose.db.yml down -v",
		"db:studio": "prisma studio",
		"db:seed": "tsx prisma/seed.ts",
		"redis:up": "docker compose -f docker-compose.redis.yml up -d",
		"redis:down": "docker compose -f docker-compose.redis.yml down",
		"redis:reset": "docker compose -f docker-compose.redis.yml down -v",
		"redis:logs": "docker compose -f docker-compose.redis.yml logs -f",
		"obs:up": "docker compose -f docker-compose.observability.yml up -d",
		"obs:down": "docker compose -f docker-compose.observability.yml down",
		"obs:reset": "docker compose -f docker-compose.observability.yml down -v",
		"obs:logs": "docker compose -f docker-compose.observability.yml logs -f",
		"prod:build": "docker compose -f docker-compose.prod.yml build",
		"prod:up": "docker compose -f docker-compose.prod.yml up -d",
		"prod:down": "docker compose -f docker-compose.prod.yml down",
		"prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
		"format": "prettier --write \"src/\"",
		"prettier:check": "prettier --check .",
		"prettier:fix": "prettier --write ."
	},
	"prettier": "@sapphire/prettier-config",
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx}": [
			"eslint --max-warnings=0 --fix",
			"prettier --write"
		],
		"**/*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
